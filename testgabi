local activeTween_ref = nil
local function moveBehindBoss()
	local m=getModel(); if not m then return end
	local root=m:FindFirstChild("HumanoidRootPart") or m:FindFirstChildWhichIsA("BasePart"); if not root then return end
	local hrp=getHRP(); if not hrp then return end
	local cf=root.CFrame*CFrame.new(0,0,STUDS)
