-- Webhook
local function getItem(n) local i=LP.Backpack:FindFirstChild(n); return i and (i:GetAttribute("ItemAmount") or 0) or 0 end
local function sendWebhook()
	if webhookURL:find("YOUR_WEBHOOK") then return false,"No URL set" end
	local ok,data=pcall(function() return HttpService:JSONEncode({username="Inventory Tracker",embeds={{title="📦 "..LP.Name.."'s Inventory",color=0x9B59B6,fields={{name="Rokakaka",value=tostring(getItem("Rokakaka")),inline=true},{name="Stand Arrow",value=tostring(getItem("Stand Arrow")),inline=true},{name="Charged Arrow",value=tostring(getItem("Charged Arrow")),inline=true}},footer={text="interval: "..webhookInterval.."s"},timestamp=os.date("!%Y-%m-%dT%H:%M:%SZ")}}}) end)
	if not ok then return false,"Encode error" end
	local s,r=pcall(function() return (http and http.request or request)({Url=webhookURL,Method="POST",Headers={["Content-Type"]="application/json"},Body=data}) end)
	if s and r and r.StatusCode==204 then webhookSendCount=webhookSendCount+1; if webhookCountLabel then webhookCountLabel.Text="Sent: "..webhookSendCount end; return true,"OK" end
	return false,"Status: "..((s and r) and tostring(r.StatusCode) or "err")
end
task.spawn(function() while true do if webhookActive then local now=tick(); if now-lastWebhookSend>=webhookInterval then lastWebhookSend=now; sendWebhook() end; task.wait(1) else task.wait(0.5) end end end)

-- Stand Roll
local function sendStandAlert(attr)
	if standWebhookURL:find("YOUR_STAND") then return end
	local sn="Unknown"; pcall(function() local l=getStandNameLabel(); if l then sn=((l.ContentText or l.Text or ""):match("^Stand:%s*(.+)$") or l.Text or "Unknown") end end)
	local mc=(standMentionID~="") and ("<@"..standMentionID..">") or ""
	local ok,data=pcall(function() return HttpService:JSONEncode({content=mc,username="Attribute Sniper",embeds={{title="Target Found!",color=0x00FF00,fields={{name="Stand",value=sn,inline=true},{name="Attribute",value=attr,inline=true}},timestamp=os.date("!%Y-%m-%dT%H:%M:%SZ")}}}) end)
	if not ok then return end
	pcall(function() local fn=(http and http.request) or request; if fn then fn({Url=standWebhookURL,Method="POST",Headers={["Content-Type"]="application/json"},Body=data}) end end)
end
local function checkStopList()
	local l=getAttrLabel(); if not l then return false,"" end
	local ct=l.ContentText or l.Text or ""
	for _,w in ipairs(standStopList) do if ct:find(w,1,true) then return true,ct end end
	return false,ct
end
local function equipAndUse(name)
	local c=LP.Character or LP.CharacterAdded:Wait()
	local h=c:WaitForChild("Humanoid",5); if not h then return false end
	local item=LP.Backpack:FindFirstChild(name) or c:FindFirstChild(name); if not item then return false end
	h:EquipTool(item); task.wait(0.5)
	local ev=getUseEvent(); if ev then pcall(function() ev:FireServer() end) end
	return true
end
task.spawn(function()
	while true do
		if not standRollActive then task.wait(0.2)
		else
			local stop,attr=checkStopList()
			local function stopRoll(a) standRollActive=false; if a then sendStandAlert(a) end
				if standStatusLabel then standStatusLabel.Text=(a and "Stopped: "..a or "Error"); standStatusLabel.TextColor3=(a and Color3.fromRGB(100,230,140) or Color3.fromRGB(255,80,80)) end
				if standRollLabel   then standRollLabel.Text="OFF" end
				if _setStandVis     then _setStandVis(false) end
			end
			if stop then stopRoll(attr)
			else
				standRollCount=standRollCount+1
				if standStatusLabel then standStatusLabel.Text="Rolling... #"..standRollCount; standStatusLabel.TextColor3=Color3.fromRGB(200,170,255) end
				if not equipAndUse("Rokakaka") then stopRoll(nil)
				else task.wait(3)
					if not equipAndUse("Charged Arrow") then stopRoll(nil)
					else task.wait(2.5)
						local sf,af=checkStopList()
						if sf then stopRoll(af) else task.wait(standLoopCD) end
					end
				end
			end
		end
	end
end)

-- Kill Timer loop
task.spawn(function()
	while true do
		if killTimerActive then
			local m=getModel(); local h=m and getHum(m)
			if h and h.Health>0 then
				if killTimerHP==nil then killTimerHP=h.Health; killTimerStart=tick() end
				local elapsed=tick()-killTimerStart
				local rem=math.max(0,killTimerDur-elapsed)
				if _ktStatusTxt then _ktStatusTxt.Text=string.format("Kill in: %.1fs",rem); _ktStatusTxt.TextColor3=rem>5 and Color3.fromRGB(80,255,155) or Color3.fromRGB(255,75,75) end
				if _ktStatusDot then _ktStatusDot.BackgroundColor3=rem>5 and Color3.fromRGB(80,255,155) or Color3.fromRGB(255,75,75) end
				if elapsed>=killTimerDur then
					if _ktStatusTxt then _ktStatusTxt.Text="Timed out! Resetting..." end
					pcall(function() local c=LP.Character; if c then local hu=c:FindFirstChildWhichIsA("Humanoid"); if hu then hu.Health=0 end end end)
					task.wait(2); killTimerHP=nil; killTimerStart=tick()
				end
			else
				killTimerHP=nil; killTimerStart=tick()
				if _ktStatusTxt then _ktStatusTxt.Text="Waiting for boss..."; _ktStatusTxt.TextColor3=Color3.fromRGB(100,90,145) end
				if _ktStatusDot then _ktStatusDot.BackgroundColor3=Color3.fromRGB(100,90,145) end
			end
			task.wait(0.1)
		else
			if _ktStatusTxt then _ktStatusTxt.Text="Timer: off"; _ktStatusTxt.TextColor3=Color3.fromRGB(100,90,145) end
			if _ktStatusDot then _ktStatusDot.BackgroundColor3=Color3.fromRGB(100,90,145) end
			killTimerHP=nil; task.wait(0.2)
		end
	end
end)

