		if activeTween_ref then activeTween_ref:Cancel() end
		activeTween_ref=TweenService:Create(hrp,TweenInfo.new(TTIME,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{CFrame=cf})
		activeTween_ref:Play()
	else hrp.CFrame=cf end
end

