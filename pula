-- TAB SWITCHER
-- ══════════════════════════════════════════════
local allContents = {
	spam    = spamContent,
	webhook = webhookContent,
	stand   = standContent,
	quest   = questContent,   -- Fix 4: quest tab registered so switchTab hides/shows it correctly
}

local function switchTab(tab)
	for id, content in pairs(allContents) do
		content.Visible = (id == tab)
	end
	bodyArea.CanvasPosition = Vector2.new(0, 0)

	-- Close quest dropdown when leaving the quest tab
	if tab ~= "quest" and qDropOpen then
		qDropOpen = false
		qDropList.Visible = false
	end

	local th = THEME[tab]
	tw(frameBorder, 0.22, {Color = th.pri})
	tw(glowFrame,   0.22, {BackgroundColor3 = th.pri})
	tw(topCap,      0.22, {BackgroundColor3 = th.glow})
	tw(titleLbl,    0.22, {TextColor3 = th.text})
	tw(iconBadge,   0.22, {BackgroundColor3 = th.pri})

	for id, p in pairs(tabPills) do
		local on = (id == tab)
		tw(p.btn,  0.18, {TextColor3 = on and p.col or DIM})
		tw(p.pill, 0.18, {BackgroundTransparency = on and 0.80 or 1})
		tw(p.line, 0.18, {BackgroundTransparency = on and 0 or 1})
	end
end

switchTab("spam")

for id, p in pairs(tabPills) do
	local capturedId = id
	p.btn.MouseButton1Click:Connect(function() switchTab(capturedId) end)
end

