-- ══════════════════════════════════════════════
-- QUEST LOGIC
-- ══════════════════════════════════════════════
local function questDoAttacks()
	local c = LocalPlayer.Character; if not c then return end
	local se = c:FindFirstChild("StandEvents"); if not se then return end
	if QS.attackEnabled.M1 then
		local r = se:FindFirstChild("M1"); if r then pcall(function() r:FireServer() end) end
		task.wait(QS.attackDelay)
	end
	if QS.attackEnabled.Barrage then
		local r = se:FindFirstChild("Barrage"); if r then pcall(function() r:FireServer(true) end) end
		task.wait(QS.attackDelay)
	end
	if QS.attackEnabled.Heavy then
		local r = se:FindFirstChild("Heavy"); if r then pcall(function() r:FireServer() end) end
		task.wait(QS.attackDelay)
	end
end

local function questGetEnemies(enemyName)
	local enemies = {}
	local living = workspace:FindFirstChild("Living"); if not living then return enemies end
	for _, obj in ipairs(living:GetChildren()) do
		if obj.Name == enemyName then
			local hum = obj:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then table.insert(enemies, obj) end
		end
	end
	return enemies
end

local function questIsAlive(enemy)
	local hum = enemy:FindFirstChildOfClass("Humanoid")
	return hum and hum.Health > 0
end

local function questTeleportBehind(enemy)
	local hrp = getRootPart(); if not hrp then return end
	local eHRP = enemy:FindFirstChild("HumanoidRootPart"); if not eHRP then return end
	hrp.CFrame = eHRP.CFrame * CFrame.new(0, 0, 5)
end

local function questKillEnemy(enemy)
	while QS.running and questIsAlive(enemy) do
		questTeleportBehind(enemy)
		questDoAttacks()
		task.wait(0.05)
	end
end

local function questGetPlayerLevel()
	local ok, val = pcall(function() return LocalPlayer.Data.Value end)
	if ok and type(val) == "number" then return val end
	for _, obj in ipairs(LocalPlayer:GetDescendants()) do
		if obj.Name == "Level" and (obj:IsA("IntValue") or obj:IsA("NumberValue")) then
			return obj.Value
		end
	end
	return 0
end

local function questGetSmart()
	local level = questGetPlayerLevel()
	local best = nil
	for _, q in ipairs(Quests) do
		if q.level <= level then best = q end
	end
	return best
end

local function questRunRemoteLoop()
	while QS.running do
		if questActive.value then
			pcall(questActive.value.take)
			pcall(questActive.value.done)
		end
		task.wait(0.5)
	end
end

local function questRun(startQuest)
	questActive.value = startQuest
	task.spawn(questRunRemoteLoop)
	while QS.running do
		if QS.smartQuest then
			local smart = questGetSmart()
			if smart and smart.name ~= questActive.value.name then
				questActive.value   = smart
				QS.selectedQuest    = smart
				if questDropBtn   then questDropBtn.Text   = "▼  " .. smart.name end
				if questStatusLbl then questStatusLbl.Text = "Smart — " .. smart.name end
			end
		end
		local timeout = tick() + 120
		repeat
			local enemies = questGetEnemies(questActive.value.enemyName)
			if #enemies > 0 then questKillEnemy(enemies[1]); task.wait(0.2)
			else task.wait(0.3) end
		until not QS.running or tick() > timeout
		task.wait(0.2)
	end
end

