-- ══════════════════════════════════════════════
-- BOSS HELPERS
-- ══════════════════════════════════════════════
local function getModel()
	local living = workspace:FindFirstChild("Living")
	if not living then return nil end
	return living:FindFirstChild("Boss")
end

local function getModelHumanoid(model)
	if not model then return nil end
	return model:FindFirstChildWhichIsA("Humanoid", true)
end

local function getCharacter()
	return LocalPlayer.Character
end

local function getRootPart()
	local char = getCharacter()
	if not char then return nil end
	return char:FindFirstChild("HumanoidRootPart")
end

local function getBehindCFrame(model)
	local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChildWhichIsA("BasePart")
	if not root then return nil end
	return root.CFrame * CFrame.new(0, 0, STUDS_BEHIND)
end

-- ══════════════════════════════════════════════
-- MOVEMENT
-- ══════════════════════════════════════════════
local activeTween = nil
local function moveBehindBoss()
	local model = getModel(); if not model then return end
	local targetCF = getBehindCFrame(model); if not targetCF then return end
	local hrp = getRootPart(); if not hrp then return end
	if useTween then
		if activeTween then activeTween:Cancel() end
		activeTween = TweenService:Create(hrp, TweenInfo.new(TWEEN_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = targetCF})
		activeTween:Play()
	else
		hrp.CFrame = targetCF
	end
end

